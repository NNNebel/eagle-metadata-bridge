# Deny everything by default
*

# Allow project files
!.gitignore
!__init__.py
!nodes.py
!executor.py
!requirements.txt
!node_dictionary.json
!web/
!web/*.js

# Public-facing files
!LICENSE
!README.md
!CHANGELOG.md
!assets/
!assets/*.png
!assets/*.jpg
!examples/
!examples/*.webp
!examples/*.png
!examples/*.json

# Allow CI and test infrastructure
!.github/
!.github/workflows/
!.github/workflows/*.yml
!tests/
!tests/pytest.ini
!tests/conftest.py
!tests/test_*.py
# Expected: bridge-*.json are committed as cross-repo contract
!tests/expected/
!tests/expected/bridge-*.json
!tests/expected/sample/
!tests/expected/sample/*.json
# Eagle client package
!eagle/
!eagle/__init__.py
!eagle/client.py

# Metadata parser package
!metadata_parser/
!metadata_parser/__init__.py
!metadata_parser/graph.py
!metadata_parser/sampler_analyzer.py
!metadata_parser/comfyui_parser.py
!metadata_parser/tag_generator.py
!metadata_parser/annotation.py

# Scripts
!scripts/
!scripts/sync_fixtures.py
!scripts/check_metadata.py
