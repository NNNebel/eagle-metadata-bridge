# Deny everything by default
*

# Allow project files
!.gitignore
!__init__.py
!nodes.py
!executor.py
!requirements.txt
!check_metadata.py
!node_dictionary.json
!web/
!web/*.js

# Allow CI and test infrastructure
!.github/
!.github/workflows/
!.github/workflows/*.yml
!conftest.py
!pytest.ini
!tests/
!tests/pytest.ini
!tests/conftest.py
!tests/test_*.py
# Fixtures: no bridge-*.json (images are in comfyui-auto-tagger)
!tests/fixtures/
!tests/fixtures/sample/
!tests/fixtures/sample/*.json
# Expected: bridge-*.json contain annotation only (no workflow data) — safe to commit
!tests/expected/
!tests/expected/bridge-*.json
!tests/expected/sample/
!tests/expected/sample/*.json
# Local copy script
!scripts/
!scripts/sync_fixtures.py
