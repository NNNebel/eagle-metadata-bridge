# Deny everything by default
*

# Allow project files
!.gitignore
!__init__.py
!nodes.py
!executor.py
!requirements.txt
!node_dictionary.json
!web/
!web/*.js

# Public-facing files
!LICENSE
!README.md
!CHANGELOG.md
!assets/
!assets/*.png
!assets/*.jpg
!examples/
!examples/*.webp
!examples/*.png
!examples/*.json

# Allow CI and test infrastructure
!.github/
!.github/workflows/
!.github/workflows/*.yml
!tests/
!tests/pytest.ini
!tests/conftest.py
!tests/test_*.py
# Fixtures: no bridge-*.json (images are in comfyui-auto-tagger)
!tests/fixtures/
!tests/fixtures/sample/
!tests/fixtures/sample/*.json
# Expected: bridge-*.json are committed as cross-repo contract
!tests/expected/
!tests/expected/bridge-*.json
!tests/expected/sample/
!tests/expected/sample/*.json
# Scripts
!scripts/
!scripts/sync_fixtures.py
!scripts/check_metadata.py
